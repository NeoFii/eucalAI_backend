# =============================================================================
# Inference Service Environment Configuration Template
# Copy to .env and fill in actual values
#
# Inference-service does NOT need: database, JWT, Redis, Snowflake, password
# policy, SMTP, cookies, bootstrap admin, channel routing, rate limiting.
# =============================================================================

# -----------------------------------------------------------------------------
# Service identity & runtime
# -----------------------------------------------------------------------------
DEBUG=false
ENV=production
TIMEZONE=Asia/Shanghai

INFERENCE_HOST=0.0.0.0

# CORS — inference-service is internal-only, callers authenticate via secret
ALLOWED_HOSTS=*

# -----------------------------------------------------------------------------
# Auth
# Both must match the corresponding values on router-service / admin-service
# -----------------------------------------------------------------------------
# Generate: openssl rand -hex 32
INTERNAL_SECRET=CHANGEME-generate-with-openssl-rand-hex-32
INTERNAL_REQUEST_TTL_SECONDS=30

# Generate: openssl rand -hex 16
# Used to authenticate router-service → inference-service calls
INFERENCE_SERVICE_SECRET=CHANGEME-generate-with-openssl-rand-hex-16

# Set to true ONLY for local dev to bypass INFERENCE_SERVICE_SECRET check
INFERENCE_ALLOW_INSECURE_DEV=false

# Internal HTTP client (calling admin-service for config refresh)
INTERNAL_HTTP_MAX_RETRIES=1
INTERNAL_HTTP_RETRY_BACKOFF_SECONDS=0.2
INTERNAL_HTTP_CIRCUIT_BREAKER_THRESHOLD=3
INTERNAL_HTTP_CIRCUIT_BREAKER_COOLDOWN_SECONDS=30

# -----------------------------------------------------------------------------
# Service discovery
# -----------------------------------------------------------------------------
ADMIN_SERVICE_URL=http://<BACKEND_IP>:8001

# -----------------------------------------------------------------------------
# Runtime config & model paths
# -----------------------------------------------------------------------------
ROUTER_RUNTIME_CONFIG=/app/config/runtime_config.json
ROUTER_MODEL_PATHS=/app/config/model_paths.json

CONFIG_REFRESH_INTERVAL_SECONDS=60
CONFIG_FETCH_TIMEOUT_SECONDS=5

# -----------------------------------------------------------------------------
# GPU
# -----------------------------------------------------------------------------
CUDA_VISIBLE_DEVICES=0
GPU_CONCURRENCY_LIMIT=8

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_PREFIX=inference
LOG_TO_FILE=true
LOG_FILE_MAX_BYTES=52428800
LOG_FILE_BACKUP_COUNT=5
LOG_MAX_DAYS=30
LOG_RING_BUFFER_CAPACITY=2000
