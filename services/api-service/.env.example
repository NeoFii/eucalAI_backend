# ============================================================
# EucalAI API Service — Environment Variables
# Copy to .env and fill in actual values before running.
# ============================================================

# --- Required (startup validation will fail without these) ---

JWT_SECRET_KEY=your-secret-key-at-least-32-characters-long-here
INTERNAL_SECRET=your-internal-secret-at-least-32-chars-here
PROVIDER_SECRET_MASTER_KEY=your-aes256-master-key-base64-here

# --- Database ---

DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/eucal_ai

# --- Redis ---

REDIS_URL=redis://127.0.0.1:6379/0
CACHE_REDIS_URL=redis://127.0.0.1:6379/2
WORKER_QUEUE_REDIS_URL=redis://127.0.0.1:6379/1

# --- Service ---

ENV=development
DEBUG=true
PORT=8000
SNOWFLAKE_WORKER_ID=1

# --- Inference Service ---

INFERENCE_SERVICE_URL=http://127.0.0.1:8004
INFERENCE_SERVICE_SECRET=

# --- SMTP (optional) ---

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
