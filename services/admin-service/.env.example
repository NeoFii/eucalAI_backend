# =============================================================================
# Admin Service Environment Configuration Template
# Copy to .env and fill in actual values
# =============================================================================

# -----------------------------------------------------------------------------
# Service identity & runtime
# -----------------------------------------------------------------------------
DEBUG=false
ENV=production
TIMEZONE=Asia/Shanghai

# CORS — comma-separated origins. PRODUCTION_ALLOWED_HOSTS is used when DEBUG=false
ALLOWED_HOSTS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3001
PRODUCTION_ALLOWED_HOSTS=https://admin.yourdomain.com

# -----------------------------------------------------------------------------
# Database (admin database)
# -----------------------------------------------------------------------------
ADMIN_DATABASE_URL=mysql+aiomysql://root:password@mysql:3306/eucal_ai_admin
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
ADMIN_QUEUE_REDIS_URL=redis://redis:6379/3
ADMIN_WORKER_CONCURRENCY=3
ADMIN_JOB_TIMEOUT_SECONDS=600

# -----------------------------------------------------------------------------
# Auth & Security (must match user-service for cross-service trust)
# -----------------------------------------------------------------------------
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=CHANGEME-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Generate: openssl rand -hex 32
INTERNAL_SECRET=CHANGEME-generate-with-openssl-rand-hex-32
INTERNAL_REQUEST_TTL_SECONDS=30

# Generate: openssl rand -hex 32  (64-char hex = 32-byte AES-256 key)
PROVIDER_SECRET_MASTER_KEY=CHANGEME-generate-64-char-hex-via-openssl-rand-hex-32

# Cookies — auto-forced to secure/strict when DEBUG=false
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# Internal HTTP client (cross-service calls)
INTERNAL_HTTP_MAX_RETRIES=1
INTERNAL_HTTP_RETRY_BACKOFF_SECONDS=0.2
INTERNAL_HTTP_CIRCUIT_BREAKER_THRESHOLD=3
INTERNAL_HTTP_CIRCUIT_BREAKER_COOLDOWN_SECONDS=30

# -----------------------------------------------------------------------------
# Service discovery
# -----------------------------------------------------------------------------
USER_SERVICE_URL=http://user-service:8000
ROUTER_SERVICE_URL=http://<GPU_IP>:8003
INFERENCE_SERVICE_URL=http://<GPU_IP>:8004

# -----------------------------------------------------------------------------
# Snowflake distributed IDs (worker_id must be unique per process across cluster)
# -----------------------------------------------------------------------------
SNOWFLAKE_WORKER_ID=2
SNOWFLAKE_DATACENTER_ID=1

# -----------------------------------------------------------------------------
# Bootstrap superadmin (run once on first deploy)
# -----------------------------------------------------------------------------
BOOTSTRAP_SUPERADMIN_ENABLED=false
BOOTSTRAP_SUPERADMIN_REQUIRE_ON_STARTUP=true
BOOTSTRAP_SUPERADMIN_EMAIL=admin@yourdomain.com
BOOTSTRAP_SUPERADMIN_PASSWORD=ChangeMeStrongPassword123!
BOOTSTRAP_SUPERADMIN_NAME=System Admin
BOOTSTRAP_SUPERADMIN_RESET_PASSWORD_IF_EXISTS=false
BOOTSTRAP_SUPERADMIN_UPDATE_NAME_IF_EXISTS=false

# -----------------------------------------------------------------------------
# Health check (channel/provider liveness probes)
# -----------------------------------------------------------------------------
HEALTH_CHECK_LLM_PROBE_ENABLED=true
HEALTH_CHECK_LLM_PROBE_MAX_TOKENS=5
HEALTH_CHECK_TIMEOUT_SECONDS=15
HEALTH_CHECK_RATE_LIMIT_DELAY=0.5

# -----------------------------------------------------------------------------
# Password policy (used by admin auth + propagated to user-service via API)
# -----------------------------------------------------------------------------
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_PREFIX=admin
LOG_TO_FILE=true
LOG_FILE_MAX_BYTES=52428800
LOG_FILE_BACKUP_COUNT=5
LOG_MAX_DAYS=30
LOG_RING_BUFFER_CAPACITY=2000
