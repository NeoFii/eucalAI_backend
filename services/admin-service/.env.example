# admin-service environment
# Copy to .env and adjust values for your environment.

# Database
ADMIN_DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/eucal_ai_admin
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# Auth & Security
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
INTERNAL_SECRET=replace-with-a-shared-random-secret
PROVIDER_SECRET_MASTER_KEY=replace-with-64-char-hex-aes256-key
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
ALLOWED_HOSTS=http://localhost:5173,http://localhost:3000

# Service Discovery
USER_SERVICE_URL=http://localhost:8000
ROUTER_SERVICE_URL=http://localhost:8003
INFERENCE_SERVICE_URL=http://localhost:8004

# Redis
REDIS_URL=redis://localhost:6379/0
ADMIN_QUEUE_REDIS_URL=redis://localhost:6379/3

# Snowflake IDs
SNOWFLAKE_WORKER_ID=2
SNOWFLAKE_DATACENTER_ID=1

# Bootstrap Superadmin
BOOTSTRAP_SUPERADMIN_ENABLED=false
BOOTSTRAP_SUPERADMIN_REQUIRE_ON_STARTUP=true
BOOTSTRAP_SUPERADMIN_EMAIL=founder@example.com
BOOTSTRAP_SUPERADMIN_PASSWORD=StrongPassword123!
BOOTSTRAP_SUPERADMIN_NAME=System Founder
BOOTSTRAP_SUPERADMIN_RESET_PASSWORD_IF_EXISTS=false
BOOTSTRAP_SUPERADMIN_UPDATE_NAME_IF_EXISTS=false

# Health Check
HEALTH_CHECK_LLM_PROBE_ENABLED=true
HEALTH_CHECK_TIMEOUT_SECONDS=15
HEALTH_CHECK_RATE_LIMIT_DELAY=0.5

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=false
LOG_FILE_PREFIX=admin
LOG_FILE_MAX_BYTES=52428800
LOG_FILE_BACKUP_COUNT=5
DEBUG=true
