# =============================================================================
# Router Service Environment Configuration Template
# Copy to .env and fill in actual values
#
# Router-service does NOT need: database, JWT, Redis (cache), Snowflake,
# password policy, SMTP, cookies, bootstrap admin.
# =============================================================================

# -----------------------------------------------------------------------------
# Service identity & runtime
# -----------------------------------------------------------------------------
DEBUG=false
ENV=production
TIMEZONE=Asia/Shanghai

# CORS — typically not needed for router (called by user-frontend backend-side
# proxy and direct API consumers), keep minimal
ALLOWED_HOSTS=*

# -----------------------------------------------------------------------------
# Auth — only INTERNAL_SECRET is required (no JWT, no cookies)
# Must match the value used in admin-service / user-service / inference-service
# -----------------------------------------------------------------------------
# Generate: openssl rand -hex 32
INTERNAL_SECRET=CHANGEME-generate-with-openssl-rand-hex-32
INTERNAL_REQUEST_TTL_SECONDS=30

# Secret used to authenticate calls to inference-service
# Must match INFERENCE_SERVICE_SECRET on inference-service
INFERENCE_SERVICE_SECRET=CHANGEME-generate-with-openssl-rand-hex-16

# Internal HTTP client (cross-service calls)
INTERNAL_HTTP_MAX_RETRIES=1
INTERNAL_HTTP_RETRY_BACKOFF_SECONDS=0.2
INTERNAL_HTTP_CIRCUIT_BREAKER_THRESHOLD=3
INTERNAL_HTTP_CIRCUIT_BREAKER_COOLDOWN_SECONDS=30

# -----------------------------------------------------------------------------
# Service discovery
# -----------------------------------------------------------------------------
USER_SERVICE_URL=http://<BACKEND_IP>:8000
ADMIN_SERVICE_URL=http://<BACKEND_IP>:8001
INFERENCE_SERVICE_URL=http://127.0.0.1:8004

# -----------------------------------------------------------------------------
# Runtime config (path to JSON describing model→provider mapping, weights, etc.)
# Hot-reloaded at runtime.
# -----------------------------------------------------------------------------
ROUTER_RUNTIME_CONFIG=/app/config/runtime_config.json

# -----------------------------------------------------------------------------
# Redis (optional — degrades to in-memory caches when empty)
# -----------------------------------------------------------------------------
ROUTER_REDIS_URL=
CHANNEL_HEALTH_REDIS_URL=

# -----------------------------------------------------------------------------
# Config refresh (pull updates from admin-service)
# -----------------------------------------------------------------------------
CONFIG_REFRESH_INTERVAL_SECONDS=60
CONFIG_FETCH_TIMEOUT_SECONDS=5

# -----------------------------------------------------------------------------
# Channel routing
# -----------------------------------------------------------------------------
CHANNEL_MAX_RETRIES=2
CHANNEL_COOLDOWN_SECONDS=30
CHANNEL_AUTO_DISABLE_ENABLED=true
CHANNEL_AUTO_DISABLE_FAILURE_THRESHOLD=5
CHANNEL_AUTO_DISABLE_COOLDOWN_SECONDS=300
CHANNEL_AFFINITY_ENABLED=false
CHANNEL_AFFINITY_TTL=3600
CHANNEL_AFFINITY_LRU_MAXSIZE=10000

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_USER_RPM=20
RATE_LIMIT_GLOBAL_RPM=0

# -----------------------------------------------------------------------------
# Call log buffer (batched flush to user-service)
# -----------------------------------------------------------------------------
CALLLOG_FLUSH_INTERVAL=5.0
CALLLOG_MAX_BUFFER=10000
CALLLOG_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# Upstream LLM provider API keys
# Referenced by ${VAR} placeholders in runtime_config.json
# Add/remove entries to match your actual upstream providers.
# -----------------------------------------------------------------------------
AUTODL_API_KEY=your-autodl-api-key
AIPING_API_KEY=your-aiping-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
ROUTER_LOG_DIR=logs
LOG_FILE_PREFIX=router
LOG_TO_FILE=true
LOG_FILE_MAX_BYTES=52428800
LOG_FILE_BACKUP_COUNT=5
LOG_MAX_DAYS=30
LOG_RING_BUFFER_CAPACITY=2000
