# =============================================================================
# User Service Environment Configuration Template
# Copy to .env and fill in actual values
# =============================================================================

# -----------------------------------------------------------------------------
# Service identity & runtime
# -----------------------------------------------------------------------------
DEBUG=false
ENV=production
TIMEZONE=Asia/Shanghai

# CORS — used by user-facing frontend
ALLOWED_HOSTS=http://localhost:3000,http://127.0.0.1:3000
PRODUCTION_ALLOWED_HOSTS=https://www.yourdomain.com,https://yourdomain.com

# -----------------------------------------------------------------------------
# Database (user database)
# -----------------------------------------------------------------------------
USER_DATABASE_URL=mysql+aiomysql://root:password@mysql:3306/eucal_ai_user
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
USER_QUEUE_REDIS_URL=redis://redis:6379/1
CACHE_REDIS_URL=redis://redis:6379/2
USER_WORKER_CONCURRENCY=5
USER_JOB_TIMEOUT_SECONDS=300

# -----------------------------------------------------------------------------
# Auth & Security (must match admin-service for cross-service trust)
# -----------------------------------------------------------------------------
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=CHANGEME-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Generate: openssl rand -hex 32
INTERNAL_SECRET=CHANGEME-generate-with-openssl-rand-hex-32
INTERNAL_REQUEST_TTL_SECONDS=30

# Cookies — auto-forced to secure/strict when DEBUG=false
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# Internal HTTP client
INTERNAL_HTTP_MAX_RETRIES=1
INTERNAL_HTTP_RETRY_BACKOFF_SECONDS=0.2
INTERNAL_HTTP_CIRCUIT_BREAKER_THRESHOLD=3
INTERNAL_HTTP_CIRCUIT_BREAKER_COOLDOWN_SECONDS=30

# -----------------------------------------------------------------------------
# Service discovery
# -----------------------------------------------------------------------------
ADMIN_SERVICE_URL=http://admin-service:8001

# -----------------------------------------------------------------------------
# Snowflake distributed IDs
# -----------------------------------------------------------------------------
SNOWFLAKE_WORKER_ID=1
SNOWFLAKE_DATACENTER_ID=1

# -----------------------------------------------------------------------------
# SMTP (email verification codes)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_TLS=true
SMTP_FROM=Eucal AI

# -----------------------------------------------------------------------------
# User & verification limits
# -----------------------------------------------------------------------------
EMAIL_CODE_EXPIRE_MINUTES=5
CODE_DAILY_SEND_LIMIT=3
MAX_CODE_ERRORS=5
CODE_ERROR_LOCK_HOURS=24
VERIFICATION_CODE_RETENTION_DAYS=7

LOGIN_MAX_FAILURES=5
LOGIN_LOCK_DURATION_HOURS=1

MAX_API_KEYS_PER_USER=20
MIN_TOPUP_AMOUNT=1000000
MAX_TOPUP_AMOUNT=10000000000

# -----------------------------------------------------------------------------
# Password policy (validated locally + propagated from admin-service)
# -----------------------------------------------------------------------------
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_PREFIX=user
LOG_TO_FILE=true
LOG_FILE_MAX_BYTES=52428800
LOG_FILE_BACKUP_COUNT=5
LOG_MAX_DAYS=30
LOG_RING_BUFFER_CAPACITY=2000
