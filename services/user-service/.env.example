# user-service environment
# Copy to .env and adjust values for your environment.

# Database
USER_DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/eucal_ai_user
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# Auth & Security
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
INTERNAL_SECRET=replace-with-a-shared-random-secret
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
ALLOWED_HOSTS=http://localhost:5173,http://localhost:3000

# Service Discovery
ADMIN_SERVICE_URL=http://localhost:8001

# Redis
REDIS_URL=redis://localhost:6379/0
USER_QUEUE_REDIS_URL=redis://localhost:6379/1
CACHE_REDIS_URL=redis://localhost:6379/2

# Snowflake IDs
SNOWFLAKE_WORKER_ID=1
SNOWFLAKE_DATACENTER_ID=1

# SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# SMTP_TLS=true
# SMTP_FROM=Eucal AI

# User Limits
EMAIL_CODE_EXPIRE_MINUTES=5
MAX_API_KEYS_PER_USER=20
LOGIN_MAX_FAILURES=5

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=false
LOG_FILE_PREFIX=user
LOG_FILE_MAX_BYTES=52428800
LOG_FILE_BACKUP_COUNT=5
DEBUG=true
