# Eucal AI 官网后端环境变量配置
# 复制此文件为 .env 并修改配置

# 项目配置
PROJECT_NAME=Eucal AI 官网 API
DEBUG=true

# CORS 配置 - 前端域名（多行用逗号分隔）
ALLOWED_HOSTS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# 联系表单配置
CONTACT_EMAIL_TO=contact@eucal.ai

# SMTP 邮件配置（可选，不配置则在控制台打印）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# SMTP_TLS=true

# ========================================
# 数据库配置
# ========================================
# MySQL 连接 URL（格式：mysql+aiomysql://用户名:密码@主机:端口/数据库名）
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/eucal_ai

# 连接池配置
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ========================================
# JWT 认证配置
# ========================================
# JWT 密钥（生产环境必须修改！建议使用随机生成的长字符串）
JWT_SECRET_KEY=your-secret-key-change-in-production

# JWT 算法
JWT_ALGORITHM=HS256

# Token 有效期
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================================
# Cookie 安全配置
# ========================================
# 是否仅 HTTPS 传输（生产环境必须设为 true）
COOKIE_SECURE=false

# SameSite 属性（lax/strict/none）
COOKIE_SAMESITE=lax

# ========================================
# 雪花 ID 配置
# ========================================
# 工作节点 ID（0-31，多实例部署时需确保唯一）
SNOWFLAKE_WORKER_ID=1

# 数据中心 ID（0-31）
SNOWFLAKE_DATACENTER_ID=1
