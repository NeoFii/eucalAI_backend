# Example environment for the Eucal AI backend.
# Copy this file to .env and adjust values for your environment.

PROJECT_NAME=Eucal AI API
DEBUG=true
ALLOWED_HOSTS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
CONTACT_EMAIL_TO=contact@eucal.ai

# SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# SMTP_TLS=true

# Shared security settings
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
INTERNAL_SECRET=replace-with-a-shared-random-secret
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Database URLs. During the transition phase these can still point at the same MySQL instance,
# but each should target a service-owned schema. There is no generic DATABASE_URL fallback.
# Router has no database.
ADMIN_DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/eucal_ai_admin
USER_DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/eucal_ai_user
CONTENT_DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/eucal_ai_content
TESTING_DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/eucal_ai_testing
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# Service URLs
# Post-consolidation: admin/user/content/testing all live inside backend-app on
# port 8001. Only router-service runs as a separate process.
ADMIN_SERVICE_URL=http://localhost:8001
USER_SERVICE_URL=http://localhost:8001
CONTENT_SERVICE_URL=http://localhost:8001
TESTING_SERVICE_URL=http://localhost:8001
ROUTER_SERVICE_URL=http://localhost:8003

# backend-app (merged admin+user+content+testing) runtime overrides
BACKEND_APP_PORT=8001
BACKEND_APP_SNOWFLAKE_WORKER_ID=1

# Snowflake IDs
SNOWFLAKE_WORKER_ID=1
SNOWFLAKE_DATACENTER_ID=1

# Testing service / benchmark worker
BENCHMARK_QUEUE_REDIS_URL=redis://127.0.0.1:6379/0
BENCHMARK_WORKER_CONCURRENCY=10
PROBE_ENABLED=true
# When using docker compose, keep PROBE_SCHEDULER_ENABLED=false on testing-service
# and enable the optional testing-scheduler profile instead.
PROBE_SCHEDULER_ENABLED=false
PROBE_CRON_HOURS=0,6,12,18
TESTING_SECRET_MASTER_KEY=

# Router service (ML inference; no DB, no HMAC)
# Override config file locations if needed; defaults resolve to deploy/router/.
# ROUTER_RUNTIME_CONFIG=./deploy/router/runtime_config.json
# ROUTER_MODEL_PATHS=./deploy/router/model_paths.json
# ROUTER_LOG_DIR=./logs

# Admin bootstrap
BOOTSTRAP_SUPERADMIN_ENABLED=false
BOOTSTRAP_SUPERADMIN_REQUIRE_ON_STARTUP=true
BOOTSTRAP_SUPERADMIN_EMAIL=founder@example.com
BOOTSTRAP_SUPERADMIN_PASSWORD=StrongPassword123!
BOOTSTRAP_SUPERADMIN_NAME=System Founder
BOOTSTRAP_SUPERADMIN_RESET_PASSWORD_IF_EXISTS=false
BOOTSTRAP_SUPERADMIN_UPDATE_NAME_IF_EXISTS=false
