# 数据库配置（必须与 MySQL 配置一致）
DB_PASSWORD=your_db_password_here
DB_NAME=eucal_ai

# JWT 配置（生产环境必须修改为随机强密钥）
JWT_SECRET_KEY=your_jwt_secret_key_here_at_least_32_chars_long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS 配置
ALLOWED_HOSTS=frontend,localhost,127.0.0.1
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# 其他
DEBUG=false
BACKEND_PORT=8000
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password_here
SMTP_TLS=true
SMTP_FROM=Eucal AI
