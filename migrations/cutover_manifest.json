{
  "version": 1,
  "execution_order": [
    "router-service",
    "testing-service",
    "admin-service",
    "user-service",
    "content-service"
  ],
  "services": [
    {
      "service": "router-service",
      "package": "router_service",
      "order": 1,
      "database_env": "ROUTER_DATABASE_URL",
      "migration_namespace": "migrations/router_service",
      "schema_snapshot": "scripts/sql/router_schema.sql",
      "owned_tables": [
        "router_api_keys",
        "router_usage_events",
        "router_billing_ledger"
      ],
      "owned_views": [],
      "internal_dependencies": [
        "user-service",
        "testing-service"
      ],
      "external_reference_columns": {
        "router_api_keys": [
          "owner_user_id"
        ],
        "router_usage_events": [
          "owner_user_id"
        ],
        "router_billing_ledger": [
          "owner_user_id"
        ]
      },
      "preconditions": [
        "ROUTER_DATABASE_URL points to a router-owned schema or database",
        "user-service internal identity endpoint is reachable",
        "testing-service internal catalog endpoint is reachable"
      ],
      "post_cutover_checks": [
        "router key CRUD endpoints succeed",
        "OpenAI-compatible proxy can resolve models through testing-service",
        "billing ledger writes succeed without shared-database foreign keys"
      ]
    },
    {
      "service": "testing-service",
      "package": "testing_service",
      "order": 2,
      "database_env": "TESTING_DATABASE_URL",
      "migration_namespace": "migrations/testing_service",
      "schema_snapshot": "scripts/sql/testing_schema.sql",
      "owned_tables": [
        "model_categories",
        "model_vendors",
        "models",
        "model_category_map",
        "providers",
        "provider_probe_configs",
        "model_provider_offerings",
        "provider_performance_metrics",
        "provider_performance_daily_stats",
        "benchmark_jobs",
        "admin_probe_audit_logs"
      ],
      "owned_views": [
        "provider_metrics_ranked"
      ],
      "internal_dependencies": [
        "admin-service"
      ],
      "external_reference_columns": {
        "benchmark_jobs": [
          "requested_by_admin_id"
        ],
        "admin_probe_audit_logs": [
          "triggered_by_admin_id"
        ]
      },
      "preconditions": [
        "TESTING_DATABASE_URL points to a testing-owned schema or database",
        "admin-service internal identity endpoint is reachable",
        "Redis benchmark queue remains available for testing-worker"
      ],
      "post_cutover_checks": [
        "internal router catalog endpoints return offerings and route candidates",
        "benchmark worker can enqueue and persist probe jobs",
        "provider_metrics_ranked view is queryable"
      ]
    },
    {
      "service": "admin-service",
      "package": "admin_service",
      "order": 3,
      "database_env": "ADMIN_DATABASE_URL",
      "migration_namespace": "migrations/admin_service",
      "schema_snapshot": "scripts/sql/admin_schema.sql",
      "owned_tables": [
        "admin_users",
        "admin_audit_logs",
        "invitation_codes"
      ],
      "owned_views": [],
      "internal_dependencies": [
        "user-service",
        "content-service"
      ],
      "external_reference_columns": {
        "invitation_codes": [
          "used_by"
        ]
      },
      "preconditions": [
        "ADMIN_DATABASE_URL points to an admin-owned schema or database",
        "bootstrap super-admin credentials are valid if bootstrap is enabled"
      ],
      "post_cutover_checks": [
        "admin login and audit log writes succeed",
        "invitation code consume and release internal endpoints succeed",
        "admin news management still proxies content-service correctly"
      ]
    },
    {
      "service": "user-service",
      "package": "user_service",
      "order": 4,
      "database_env": "USER_DATABASE_URL",
      "migration_namespace": "migrations/user_service",
      "schema_snapshot": "scripts/sql/user_schema.sql",
      "owned_tables": [
        "users",
        "user_sessions",
        "user_active_sessions",
        "email_verification_codes"
      ],
      "owned_views": [],
      "internal_dependencies": [
        "admin-service",
        "content-service",
        "router-service"
      ],
      "external_reference_columns": {},
      "preconditions": [
        "USER_DATABASE_URL points to a user-owned schema or database",
        "admin-service invitation internal endpoints are reachable",
        "router-service key API remains reachable for compatibility proxy endpoints"
      ],
      "post_cutover_checks": [
        "register/login/refresh/logout flows succeed",
        "internal user identity endpoints return the minimal contract",
        "public news reads still proxy content-service correctly"
      ]
    },
    {
      "service": "content-service",
      "package": "content_service",
      "order": 5,
      "database_env": "CONTENT_DATABASE_URL",
      "migration_namespace": "migrations/content_service",
      "schema_snapshot": "scripts/sql/content_schema.sql",
      "owned_tables": [
        "news"
      ],
      "owned_views": [],
      "internal_dependencies": [
        "admin-service",
        "user-service"
      ],
      "external_reference_columns": {
        "news": [
          "author_id",
          "deleted_by_admin_id"
        ]
      },
      "preconditions": [
        "CONTENT_DATABASE_URL points to a content-owned schema or database",
        "admin-service and user-service clients are ready to consume content-service APIs"
      ],
      "post_cutover_checks": [
        "public news listing and detail endpoints succeed",
        "admin-side create/update/publish/delete flows still operate through content-service",
        "news rows no longer rely on admin-service SQL foreign keys"
      ]
    }
  ]
}
